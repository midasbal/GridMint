# ============================================================
# GridMint — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Arc Testnet ───────────────────────────────────────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER_URL=https://testnet.arcscan.app

# ── Circle USDC on Arc (native ERC-20, 6 decimals) ────────────────────────────
USDC_CONTRACT_ADDRESS=0x3600000000000000000000000000000000000000

# ── Circle API (for Nanopayments API backend — optional) ─────────────────────
# Obtain at https://console.circle.com
# Leave blank to use native ERC-20 settlement (default, recommended)
CIRCLE_API_KEY=YOUR_CIRCLE_API_KEY_HERE
CIRCLE_ENTITY_SECRET=YOUR_CIRCLE_ENTITY_SECRET_HERE

# ── Settlement backend ────────────────────────────────────────────────────────
# erc20  — direct USDC ERC-20 transfer() on Arc (default, sub-second, on-chain proof)
# api    — Circle Nanopayments REST API (requires valid CIRCLE_API_KEY above)
CIRCLE_SETTLEMENT_BACKEND=erc20

# ── Gateway wallet (receives x402 paywall fees) ───────────────────────────────
GATEWAY_WALLET_ADDRESS=YOUR_GATEWAY_WALLET_ADDRESS_HERE

# ── Settlement mode ───────────────────────────────────────────────────────────
# live      — real USDC transfers on Arc Testnet (requires funded wallets below)
# simulated — in-memory simulation, no on-chain calls
SETTLEMENT_MODE=live

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Obtain at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Agent wallets ─────────────────────────────────────────────────────────────
# Generate with: python3 scripts/setup_wallets.py
# Fund with testnet USDC at: https://faucet.circle.com (select Arc Testnet)
SOLAR_1_PRIVATE_KEY=YOUR_SOLAR_1_PRIVATE_KEY_HERE
SOLAR_2_PRIVATE_KEY=YOUR_SOLAR_2_PRIVATE_KEY_HERE
SOLAR_3_PRIVATE_KEY=YOUR_SOLAR_3_PRIVATE_KEY_HERE
CONSUMER_1_PRIVATE_KEY=YOUR_CONSUMER_1_PRIVATE_KEY_HERE
CONSUMER_2_PRIVATE_KEY=YOUR_CONSUMER_2_PRIVATE_KEY_HERE
CONSUMER_3_PRIVATE_KEY=YOUR_CONSUMER_3_PRIVATE_KEY_HERE
CONSUMER_4_PRIVATE_KEY=YOUR_CONSUMER_4_PRIVATE_KEY_HERE
CONSUMER_5_PRIVATE_KEY=YOUR_CONSUMER_5_PRIVATE_KEY_HERE
BATTERY_1_PRIVATE_KEY=YOUR_BATTERY_1_PRIVATE_KEY_HERE
BATTERY_2_PRIVATE_KEY=YOUR_BATTERY_2_PRIVATE_KEY_HERE

# ── Simulation tuning ─────────────────────────────────────────────────────────
TICK_INTERVAL_SECONDS=3
SIMULATION_SPEED_MULTIPLIER=360

# ── CORS (for production deployment) ─────────────────────────────────────────
# Add your deployed frontend URL here alongside localhost
# Example: CORS_ORIGINS=http://localhost:5173,https://gridmint.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
